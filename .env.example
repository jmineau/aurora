# ── Twilio (required) ─────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Scheduling ────────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=30
ALERT_COOLDOWN_HOURS=6

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///aurora.db

# ── External API keys ─────────────────────────────────────────────────────────
# Free key from https://portal.opentopography.org/requestApiKey
OPENTOPOGRAPHY_API_KEY=

# ── Factor weights (exponents in the weighted-product visibility model) ───────
# 1.0 = linear;  >1 = harsher penalty;  0.0 = disable factor entirely
WEIGHT_OVATION=1.0
WEIGHT_KP=0.5
WEIGHT_CLOUD=1.5
WEIGHT_AOD=1.0
WEIGHT_ELEV=0.3
WEIGHT_MOON=0.5
WEIGHT_LP=0.5
WEIGHT_PWV=0.3
WEIGHT_HORIZ=0.5
